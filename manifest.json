{
	"manifest_version": 3,
	"name": "Smply",
	"version": "1.0",
	"description": "Shorten any page URL instantly with Smply — one click, a clean short link, ready to share.",
	"permissions": ["activeTab", "scripting", "storage"],
	"host_permissions": ["https://smply.cc/*"],
	"options_ui": {
		"page": "options/options.html",
		"open_in_tab": false
	},
	"action": {
		"default_popup": "popup/popup.html",
		"default_icon": {
			"16": "assets/icons/logo16.png",
			"32": "assets/icons/logo32.png",
			"48": "assets/icons/logo48.png"
		}
	},
	"icons": {
		"16": "assets/icons/logo16.png",
		"32": "assets/icons/logo32.png",
		"48": "assets/icons/logo48.png",
		"128": "assets/icons/logo128.png"
	}
}
